client:
  jobs:
    poll_interval: 2
server:
  address: http://your-server-ip
  front_end_port: 3011
  # during development, front_end_port += 2
  back_end_port: 8017
  # during development, back_end_port += 2
  # redirect_uri = f"{address}:{front_end_port}/auth/callback"
  root: /path/to/magnus-data
  # optional: put the per-job ephemeral overlay + apptainer tmp/cache on a
  # faster disk, decoupled from the persistent data under `root`. defaults to
  # `root` when omitted (single-disk sites need not set it). on dev runs the
  # `-develop` suffix is appended just like `root`.
  # ephemeral_root: /fast-ssd/magnus-ephemeral
  cors_origins:
    - http://your-server-ip:3011       # production frontend
    - http://localhost:3013            # dev frontend (port+2)
  # magnus_database_path = f"{server_root}/database"
  # sqlalchemy_database_url = f"sqlite:///{magnus_database_path}/magnus.db"
  # magnus_workspace_path = f"{server_root}/workspace"
  # job_working_table = f"{magnus_workspace_path}/jobs/{job.id}"
  # job_repository_path = f"{job_working_table}/repository"
  # job_wrapper_path = f"{job_working_table}/wrapper.py"
  # magnus_uv_cache = f"{server_root}/uv_cache/{user}"
  # file_custody_path = f"{server_root}/file_custody"
  database:
    pool_size: 8             # resident connections in the pool
    max_overflow: 16         # extra connections beyond pool_size (hard limit = pool_size + max_overflow)
    pool_timeout: 10         # seconds to wait for an available connection
    pool_recycle: 3600       # recycle connections after this many seconds to prevent stale handles
  auth:
    provider: feishu                     # feishu | local
    jwt_signer:
      secret_key: your-secret-key
      algorithm: HS256
      expire_minutes: 10080  # 7 days
    feishu_client:
      app_id: cli_xxxxxxxxxxxxxxxx
      app_secret: xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
      admins:                              # open_id list, empty = no admins
        - ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
      refresh_interval: 3600               # seconds between user info refreshes (avatar, name, etc.), 0 = disabled
  scheduler:
    heartbeat_interval: 2
    snapshot_interval: 300
    cluster_stats_cache_ttl: 0   # seconds to cache the cluster page's read-only SLURM
                                 # view (squeue + scontrol). 0 = always query live.
                                 # Set to a few seconds on remote (transport: ssh)
                                 # sites to cut per-poll socket round-trips; the page
                                 # then trails reality by at most this many seconds.
  service_proxy:
    max_concurrency: 1024
  file_custody:
    max_size: 10G
    max_file_size: 2G        # per-file limit, None = no limit
    max_processes: 128
    default_ttl_minutes: 60  # 1 hour
    max_ttl_minutes: 1440    # 1 day
  explorer:
    base_url: https://dashscope.aliyuncs.com/compatible-mode/v1
    model_name: qwen3-235b-a22b
    visual_model_name: qwen-vl-max
    small_fast_model_name: qwen-turbo
    stt_model_name: whisper-1
    api_key: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# transport: where magnus runs the SLURM CLI and stages each job's working tree.
# Omit entirely (default `mode: local`) when magnus shares a host with the SLURM
# controller — this is the case for self-owned clusters, and every remote path
# below collapses onto the local workspace so nothing is moved. Set `mode: ssh`
# to drive a remote multi-tenant cluster over a pre-established SSH ControlMaster
# socket (the human bootstraps the socket once with 2FA, magnus rides it): the job
# working tree (wrapper.py + dirs) is pushed to remote_root before sbatch and the
# wrapper-written markers / SLURM stdout / metrics are pulled back from there.
# transport:
#   mode: ssh                            # local | ssh
#   ssh:
#     control_path: /home/magnus/.ssh/cm-remote.sock  # absolute path (no ~): passed verbatim to ssh
#     host: login.your-hpc.example.edu
#     user: "your-cluster-account"
#     remote_root: /lustre/home/your-cluster-account/magnus-data  # REQUIRED when mode=ssh: remote job working-tree root
#     resource_staging: relay              # relay | remote (default relay). How the SIF image and git
#                                          # repo reach the remote site. relay: the magnus host (already
#                                          # on the registry/git proxy allowlist) pulls them locally and
#                                          # pushes them over; the remote site needs no outbound proxy
#                                          # access. remote: the remote site pulls them itself (requires
#                                          # its egress IP on the proxy allowlist) -- not yet wired.
#     auto_connect:                        # OPTIONAL. Omit -> the ControlMaster socket must be built by
#                                          # hand and a dead socket fast-fails. Set it to (re)build the
#                                          # socket unattended when it dies (ControlPersist expiry / host
#                                          # reboot), answering a "password + TOTP code" keyboard-interactive
#                                          # login with the account holder's own credentials. Works for any
#                                          # password + RFC 6238 TOTP SSH host. Each secret is given EITHER
#                                          # inline OR as a path to a chmod-600 file (exactly one of each):
#                                          #   password: "..."          OR  password_file: /path/to/pw      (mode 600)
#                                          #   totp_secret: "BASE32..."  OR  totp_secret_file: /path/to/seed (mode 600)
#                                          # totp_secret is the base32 seed from the otpauth:// QR you scanned.
#       totp_secret_file: /home/magnus/.config/magnus/cluster-totp.seed
#       password_file: /home/magnus/.config/magnus/cluster-login.pw
#       control_persist: 8h                # optional, master lifetime after the last use (default 8h)
#       # password_prompt / totp_prompt    # optional regexes if the host's prompt wording differs from the
#       #                                  # built-in defaults (verification code / OTP / 验证码 ... vs password / 口令)

execution:
  backend: slurm                         # slurm | local
  container_runtime: apptainer           # apptainer | singularity (slurm) | docker (local)
  allow_root: false
  resource_cache:
    container_cache_size: 80G
    repo_cache_size: 20G
  # slurm: SLURM submission dialect. Every field has a current-behavior default,
  # so self-owned sites need not set this block at all. Override for tenant
  # clusters that mandate partition/qos/account, disable `--mem`, or require
  # `module load` before the runtime is on PATH.
  # slurm:
  #   partition: your-partition          # null = don't pass --partition
  #   qos: normal                        # null = don't pass --qos
  #   account: your-account              # null = don't pass --account
  #   mem_mode: per_cpu                  # explicit (pass --mem) | per_cpu (derive cores, omit --mem)
  #   mem_per_cpu_mb: 4000               # only used when mem_mode == per_cpu
  #   module_loads:                      # `module load` lines prepended in the job script
  #     - singularity/3.11.3

cluster:
  registry_mirror: null
  # scheduling.mode: how magnus decides what/when to submit. `authoritative`
  # (default) = magnus owns the whole cluster, computes cluster-wide free
  # resources and runs its own EASY backfill + preemption. `tenant` = magnus is
  # one tenant on a shared cluster, eagerly submits up to its QOS quota and lets
  # the foreign SLURM's own fairshare/backfill do the scheduling. In tenant mode
  # the cluster page scopes its running-task list and resource totals to the
  # partition under execution.slurm.partition (the shared partition this tenant
  # competes in) instead of the whole cluster; foreign jobs in that partition are
  # shown below this tenant's own jobs, exactly as on an authoritative cluster.
  # scheduling:
  #   mode: tenant                       # authoritative | tenant
  name: Your Cluster Name
  gpus:
    -
      value: rtx5090
      label: NVIDIA GeForce RTX 5090
      meta: 32GB • Blackwell
      limit: 4
  max_cpu_count: 128
  max_memory_demand: 256G
  # max_time_limit / default_time_limit (minutes) are OPTIONAL. Omit (or null) =
  # no walltime cap and no --time emitted, so each job runs under the partition's
  # default walltime (current behavior). A per-job time_limit lets short jobs
  # declare a short walltime so a shared cluster's backfill can slot them in
  # sooner; default_time_limit imposes one on jobs that omit it.
  # max_time_limit: 1440
  # default_time_limit: null
  default_cpu_count: 4
  default_memory_demand: 1600M
  default_runner: username
  default_container_image: docker://pytorch/pytorch:2.5.1-cuda12.4-cudnn9-runtime
  default_ephemeral_storage: 10G
  default_system_entry_command: |-
    mounts=(
      "/home:/home"
    )
    export APPTAINER_BIND=$(IFS=,; echo "${mounts[*]}")
    export UV_CACHE_DIR=/path/to/magnus-data/uv_cache
